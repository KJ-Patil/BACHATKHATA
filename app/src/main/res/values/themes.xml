<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BachatKhata" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorError">@color/colorDanger</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>

        <!-- Status bar and navigation bar customization -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
    </style>

    <style name="Theme.BachatKhata" parent="Base.Theme.BachatKhata" />
    <style name="Theme.BachatKhata.Dark" parent="Base.Theme.BachatKhata" />

    <!-- SoftCard Style — mirrors the CSS:
         backgroundColor #ffffff, border 1px #e5e7eb, borderRadius 16px, padding 48px,
         textAlign center, color #64748b, fontSize 14px, boxShadow 0 1px 2px rgba(0,0,0,.05) -->
    <style name="SoftCard">
        <item name="android:background">@drawable/bg_card_soft</item>
        <item name="android:padding">48dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:elevation">2dp</item>
        <item name="android:textColor">@color/softCardText</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ClayCard Style — bold raised card with a branded (indigo-tinted) shadow. -->
    <style name="ClayCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/clay_card_radius</item>
        <item name="cardElevation">10dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="strokeColor">@color/colorCardBorder</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="android:outlineSpotShadowColor" tools:targetApi="p">@color/colorPrimary</item>
        <item name="android:outlineAmbientShadowColor" tools:targetApi="p">@color/colorPrimary</item>
    </style>

    <!-- ClayButton Style — filled, bold raised with a real elevation shadow. -->
    <style name="ClayButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/clay_button_radius</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorOnPrimary</item>
        <item name="iconTint">@color/colorOnPrimary</item>
        <item name="android:elevation">6dp</item>
        <item name="android:outlineSpotShadowColor" tools:targetApi="p">@color/colorPrimaryShadow</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- ClayButtonSecondary Style -->
    <style name="ClayButtonSecondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/clay_button_radius</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="backgroundTint">@color/colorSurface</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- ClayInput Style -->
    <style name="ClayInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/clay_input_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/clay_input_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/clay_input_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/clay_input_radius</item>
        <item name="boxStrokeColor">@color/colorCardBorder</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2.5dp</item>
        <item name="boxBackgroundColor">@color/colorSurface</item>
        <item name="hintTextColor">@color/colorPrimary</item>
    </style>

    <!-- ClayChip Style -->
    <style name="ClayChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">12dp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
    </style>

    <style name="ShapeAppearanceOverlay.ClayFab" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">19dp</item>
    </style>

    <!-- ── Floating calculator keypad ──────────────────────────────────────
         Keys share one base so the 4x5 grid stays even; variants only
         re-tint. layout_weight=1 + width=0dp makes each row self-distribute. -->
    <style name="CalcKey" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginHorizontal">4dp</item>
        <item name="cornerRadius">@dimen/clay_input_radius</item>
        <item name="backgroundTint">@color/colorSurface</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="CalcKeyOperator" parent="CalcKey">
        <item name="backgroundTint">@color/colorPrimaryLight</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="CalcKeyMuted" parent="CalcKey">
        <item name="backgroundTint">@color/colorSurfaceVariant</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="CalcKeyAccent" parent="CalcKey">
        <item name="backgroundTint">@color/colorSurfaceVariant</item>
        <item name="android:textColor">@color/colorDanger</item>
    </style>

    <style name="CalcKeyEquals" parent="CalcKey">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorOnPrimary</item>
    </style>

    <!-- Bottom navigation active indicator (soft primary pill) -->
    <style name="ShapeAppearance.BottomNavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#1F7C6FE0</item>
        <item name="android:width">56dp</item>
        <item name="android:height">36dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.BottomNavIndicator</item>
        <item name="marginHorizontal">4dp</item>
    </style>
</resources>