    <string name="gateway_caveats_title">About the Quick route</string>
    <string name="gateway_caveats_body">This uses Fast2SMS\'s Quick route, which needs no DLT registration, sender ID or pre-approved templates — hence the single API key. In exchange: messages come from a shared number, are reviewed before dispatch, and never reach numbers registered on DND.</string>
    <string name="gateway_pricing_title">Published pricing</string>
