<?xml version="1.0" encoding="utf-8"?>
<!-- Bold raised primary card — indigo fill with a darker indigo shadow base. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:left="3dp" android:right="3dp" android:top="4dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimaryShadow" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimary" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
