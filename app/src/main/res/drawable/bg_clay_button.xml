<?xml version="1.0" encoding="utf-8"?>
<!-- Bold raised 3D button: indigo surface sitting on a darker indigo base, with a
     ripple for touch feedback. The 4dp base strip at the bottom gives the pressable
     "clay" depth. Tokenised, so it adapts to light/dark. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/colorPrimaryDark">

    <item android:id="@android:id/background">
        <layer-list>
            <!-- Darker base (the 3D depth) -->
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorPrimaryShadow" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
            <!-- Button surface -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/colorPrimary" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</ripple>
