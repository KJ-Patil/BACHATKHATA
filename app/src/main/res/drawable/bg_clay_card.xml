<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow Layer (shifted down/right) -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/colorShadow" />
        </shape>
    </item>

    <!-- Main Card Layer -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/colorSurface" />
            <stroke
                android:width="1dp"
                android:color="@color/colorCardBorder" />
        </shape>
    </item>
</layer-list>
