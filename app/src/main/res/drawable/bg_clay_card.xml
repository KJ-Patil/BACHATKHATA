<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow Layer (Shifted Downwards for Elevation Offset) -->
    <item
        android:left="2dp"
        android:right="2dp"
        android:top="8dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/clay_card_radius" />
            <solid android:color="@color/colorShadow" />
        </shape>
    </item>

    <!-- Main Card Body Layer -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/clay_card_radius" />
            <solid android:color="@color/colorSurface" />
            <stroke
                android:width="1dp"
                android:color="@color/colorCardBorder" />
        </shape>
    </item>
</layer-list>
