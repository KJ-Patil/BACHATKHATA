<?xml version="1.0" encoding="utf-8"?>
<!-- Portable "soft card" look: white surface, 1dp light-gray border, 16dp rounded corners.
     Pair with android:elevation (e.g. 2dp) on the view for the subtle 0 1px 2px shadow. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/colorSurface" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="@color/softCardBorder" />
</shape>
