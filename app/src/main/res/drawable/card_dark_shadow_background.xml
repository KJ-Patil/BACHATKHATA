<?xml version="1.0" encoding="utf-8"?>
<!-- Bold raised card with a stacked drop shadow. Tokenised so the surface and shadow
     adapt to light/dark (previously the surface was hardcoded near-white). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer shadow (largest offset, softest) -->
    <item android:left="2dp" android:right="2dp" android:top="7dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorShadow" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Inner shadow (tighter, stronger) -->
    <item android:left="1dp" android:right="1dp" android:top="4dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorShadowStrong" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Card surface -->
    <item android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorSurface" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="@color/colorCardBorder" />
        </shape>
    </item>
</layer-list>
