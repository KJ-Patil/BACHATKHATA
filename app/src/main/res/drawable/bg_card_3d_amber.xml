<?xml version="1.0" encoding="utf-8"?>
<!-- 3D box with a soft light-amber face on the thin grey base. For the Weekly Insight card. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#C9C7D4" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <item
        android:bottom="4dp"
        android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FBEBD0" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</layer-list>
