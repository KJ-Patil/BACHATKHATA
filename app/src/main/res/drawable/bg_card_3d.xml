<?xml version="1.0" encoding="utf-8"?>
<!-- Bold raised "clay" card. A soft shadow strip is revealed at the bottom so the
     surface reads as lifted, entirely within the view bounds (no layout change needed).
     Colors are tokens, so it adapts to light/dark automatically. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Raised base / drop shadow -->
    <item android:left="3dp" android:right="3dp" android:top="4dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorShadow" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Card surface (leaves a 5dp shadow strip visible at the bottom) -->
    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorSurface" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="@color/colorCardBorder" />
        </shape>
    </item>
</layer-list>
