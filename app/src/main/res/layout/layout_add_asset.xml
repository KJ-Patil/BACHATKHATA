<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Handle indicator -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@color/colorDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Asset"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Asset Type Dropdown/Spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asset Type"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/ClayCard"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/colorSurfaceVariant">

            <Spinner
                android:id="@+id/spinnerAssetType"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="12dp"
                android:entries="@array/asset_types"
                android:background="@null" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Asset Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAssetName"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Asset Name (e.g. SBI Savings)"
            android:layout_marginBottom="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAssetName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Asset Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAssetAmount"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Valuation / Balance (₹)"
            android:layout_marginBottom="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAssetAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Gold Helper Card (Visible only when Gold type is selected) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGoldHelper"
            style="@style/ClayCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/colorWarningTint"
            app:strokeColor="@color/colorWarning"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪙 Gold Valuation Helper"
                    android:textColor="@color/colorWarning"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilGoldWeight"
                        style="@style/ClayInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Weight (g)"
                        android:layout_marginEnd="6dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etGoldWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilGoldRate"
                        style="@style/ClayInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:hint="Rate/gram (₹)"
                        android:layout_marginStart="6dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etGoldRate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtGoldValuationResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Calculated value: ₹0.00"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notes -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAssetNotes"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notes (Optional)"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAssetNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textShortMessage"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAsset"
            style="@style/ClayButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Asset"
            app:backgroundTint="@color/colorSuccess"
            android:textColor="@android:color/white" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
