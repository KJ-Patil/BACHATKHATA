<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/ClayCard"
    android:id="@+id/cardSavingsGoal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_3d"
        android:padding="16dp">

        <!-- Top Row: Icon + Name + Deadline -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtGoalIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗"
                android:textSize="28sp"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/txtGoalName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/txtGoalIcon"
                android:layout_marginStart="12dp"
                android:layout_centerVertical="true"
                android:text="New Car"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtGoalDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_clay_button"
                android:backgroundTint="@color/colorCardBorder"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Dec 2026"
                android:textColor="@color/colorTextSecondary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Middle Content: Circular progress + details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Progress Ring -->
            <com.example.bachatkhata.CircularProgressView
                android:id="@+id/progressRing"
                android:layout_width="80dp"
                android:layout_height="80dp" />

            <!-- Detail statistics -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtGoalSavedVsTarget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved: ₹1,50,000 / ₹5,00,000"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtGoalRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Remaining: ₹3,50,000"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtGoalMonthlyNeeded"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="₹12,500/month needed to reach goal"
                    android:textColor="@color/colorPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Action Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddFunds"
                style="@style/ClayButtonSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:textSize="12sp"
                android:text="Add Funds" />
        </RelativeLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
