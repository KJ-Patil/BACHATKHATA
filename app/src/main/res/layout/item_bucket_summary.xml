<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBucket"
    style="@style/ClayCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginTop="16dp"
    android:layout_marginEnd="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtBucketName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Needs"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtBucketStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_pill"
                android:backgroundTint="@color/colorSecondary"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="On Track"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txtBucketSpentVsLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="₹0 of ₹0"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBucket"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="12dp"
            android:progress="0"
            app:indicatorColor="@color/colorPrimary"
            app:trackColor="@color/colorCardBorder"
            app:trackCornerRadius="5dp" />

        <TextView
            android:id="@+id/txtBucketAllocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Category limits: ₹0"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp" />

        <!-- Shown when per-category limits exceed the bucket's rule limit -->
        <TextView
            android:id="@+id/txtBucketAllocationWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/colorDanger"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
