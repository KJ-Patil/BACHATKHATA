<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top App Bar Toolbar -->
    <RelativeLayout
        android:id="@+id/layoutAppBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Goal Details"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnEditToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_more"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/layoutActions"
        app:layout_constraintTop_toBottomOf="@+id/layoutAppBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Hero Progress Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/ClayCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <com.example.bachatkhata.CircularProgressView
                            android:id="@+id/progressRing"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_centerInParent="true" />

                        <TextView
                            android:id="@+id/txtHeroEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="💰"
                            android:textSize="40sp" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/txtHeroName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Savings Goal Name"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtHeroPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0% Completed"
                        android:textColor="@color/colorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- READ ONLY DETAIL LAYOUT -->
            <LinearLayout
                android:id="@+id/layoutReadMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Target Amount -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Target Amount"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailTarget"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₹10,000.00"
                                android:textColor="@color/colorTextPrimary"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Saved Amount -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Saved So Far"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailSaved"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₹2,000.00"
                                android:textColor="@color/colorSecondary"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Remaining Amount -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remaining"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailRemaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₹8,000.00"
                                android:textColor="@color/colorDanger"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Deadline -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deadline"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailDeadline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Dec 2026"
                                android:textColor="@color/colorTextPrimary"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Recommended Saving -->
                        <LinearLayout
                            android:id="@+id/layoutRecommendedSaving"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            tools:visibility="visible">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/colorCardBorder"
                                android:layout_marginBottom="12dp"/>
                            <TextView
                                android:id="@+id/txtDetailMonthlyNeeded"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="₹500.00/month needed to reach goal"
                                android:textColor="@color/colorPrimary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Deposit Activity Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Deposit History"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Deposits RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDepositHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/txtEmptyDeposits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="24dp"
                    android:gravity="center"
                    android:text="No deposit history found. Start adding funds below!"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- EDITABLE FORM LAYOUT -->
            <LinearLayout
                android:id="@+id/layoutEditMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="gone">

                <!-- Emoji Picker Grid Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Choose Icon"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Emoji Picker Grid -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvEditEmojiPicker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="4"
                        tools:listitem="@layout/item_category_grid_cell" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Editable Goal Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEditGoalName"
                    style="@style/ClayInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Goal Name">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditGoalName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textShortMessage|textCapWords"
                        android:textColor="@color/colorTextPrimary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Editable Target Amount -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEditTargetAmount"
                    style="@style/ClayInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Target Amount">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditTargetAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/colorTextPrimary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Deadline Picker -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEditDeadlinePicker"
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/imgEditCalendarIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_calendar" />

                        <TextView
                            android:id="@+id/txtEditDeadlineDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@+id/imgEditCalendarIcon"
                            android:text="Select Target Date (Optional)"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions Area -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Add Funds / Save Changes Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActionSubmit"
            style="@style/ClayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Add Funds" />

        <!-- Delete Goal Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteGoal"
            style="@style/ClayButtonSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete Goal"
            android:textColor="@color/colorDanger"
            app:strokeColor="@color/colorDanger" />
    </LinearLayout>

    <!-- Overlay Loader -->
    <FrameLayout
        android:id="@+id/loaderOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorScrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/colorPrimary" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
