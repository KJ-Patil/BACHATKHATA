<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_sheet_top"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@color/colorCardBorder" />

    <!-- Title row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Add New Account Book"
            android:textColor="@color/colorTextPrimary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/colorTextSecondary"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <!-- Form content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <!-- Type toggle -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:checkedButton="@+id/btnTypeCustomer"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeCustomer"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↗ Customer (Owes me)"
                android:textSize="11sp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeSupplier"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↙ Supplier (I owe)"
                android:textSize="11sp"
                app:cornerRadius="10dp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Contact Name label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTACT / ACCOUNT NAME"
            android:textColor="@color/colorTextSecondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Contact Name input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="e.g. Arun Kumar">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:textColor="@color/colorTextPrimary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone Number label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHONE NUMBER"
            android:textColor="@color/colorTextSecondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Phone Number input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPhone"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="e.g. 9876543210">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textColor="@color/colorTextPrimary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Used for WhatsApp reconciliation messages"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp" />

        <!-- Opening Balance label -->
        <TextView
            android:id="@+id/txtBalanceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPENING BALANCE"
            android:textColor="@color/colorTextSecondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Opening Balance input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilOpeningBalance"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etOpeningBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/colorTextPrimary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/ClayButtonSecondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreate"
                style="@style/ClayButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Create Book" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
