<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPin"
                style="@style/ClayCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/colorSurface"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- Lock badge -->
                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_login_logo"
                        android:contentDescription="@string/pin_verify_title"
                        android:padding="16dp"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/colorPrimary" />

                    <!-- Title -->
                    <TextView
                        android:id="@+id/txtPinTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:text="@string/pin_verify_title"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <!-- Subtitle -->
                    <TextView
                        android:id="@+id/txtPinSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/pin_verify_subtitle"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="14sp" />

                    <!-- PIN label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.05"
                        android:text="@string/pin_label"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- PIN input with eye toggle -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPin"
                        style="@style/ClayInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/pin_hint"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/colorTextSecondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionDone"
                            android:inputType="numberPassword"
                            android:maxLength="4"
                            android:textColor="@color/colorTextPrimary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Unlock / primary action -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUnlock"
                        style="@style/ClayButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/pin_unlock" />

                    <!-- Use fingerprint (visible only when biometric enabled) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUseFingerprint"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:text="@string/pin_use_fingerprint"
                        android:textColor="@color/colorPrimary"
                        android:visibility="gone"
                        app:icon="@drawable/ic_fingerprint"
                        app:iconGravity="textStart"
                        app:iconTint="@color/colorPrimary" />

                    <!-- Forgot PIN -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForgotPin"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:text="@string/pin_forgot"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold" />

                    <!-- Switch account -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSwitchAccount"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:letterSpacing="0.08"
                        android:text="@string/pin_switch_account"
                        android:textAllCaps="true"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Overlay Loader -->
    <FrameLayout
        android:id="@+id/loaderOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorScrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/colorPrimary" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
