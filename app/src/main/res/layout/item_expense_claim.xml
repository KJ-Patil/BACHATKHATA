<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/ClayCard"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:strokeWidth="0dp"
    app:cardCornerRadius="0dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_3d"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Submitter Details -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/txtClaimAmount">

                <TextView
                    android:id="@+id/txtClaimSubmitter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtClaimCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Food • 14 Jun 2026"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Claim Amount -->
            <TextView
                android:id="@+id/txtClaimAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="₹150.00"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Claim Note -->
        <TextView
            android:id="@+id/txtClaimNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Client lunch expense claim details here"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp" />

        <!-- Optional Receipt Preview -->
        <ImageView
            android:id="@+id/imgReceiptPreview"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_clay_button"
            android:backgroundTint="@color/colorPrimaryTint"
            android:visibility="gone"
            android:contentDescription="Receipt Image" />

        <View
            android:id="@+id/dividerAction"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@color/colorCardBorder"
            android:visibility="gone" />

        <!-- Admin Actions or Status text -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Static Status Badge -->
            <TextView
                android:id="@+id/txtClaimStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPROVED"
                android:textColor="@color/colorSecondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/bg_clay_button"
                android:backgroundTint="@color/colorSuccessTint"
                android:visibility="gone" />

            <!-- Admin Buttons -->
            <LinearLayout
                android:id="@+id/layoutAdminActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRejectClaim"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="32dp"
                    android:text="Reject"
                    android:textColor="@color/colorDanger"
                    app:iconTint="@color/colorDanger"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApproveClaim"
                    style="@style/ClayButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:minHeight="32dp"
                    android:paddingVertical="4dp"
                    android:paddingHorizontal="12dp"
                    android:text="Approve"
                    android:backgroundTint="@color/colorSecondary"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
