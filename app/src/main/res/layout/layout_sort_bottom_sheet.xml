<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:padding="24dp">

    <!-- Top drag handle / decoration -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#D1CFF5"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort Transactions"
        android:textColor="@color/colorTextPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose how you want to order your transaction list"
        android:textColor="@color/colorTextSecondary"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <!-- RadioGroup for Sorting Options -->
    <RadioGroup
        android:id="@+id/rgSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rbNewest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Newest First"
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="@color/colorPrimary"
            android:layout_marginBottom="8dp" />

        <RadioButton
            android:id="@+id/rbOldest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oldest First"
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="@color/colorPrimary"
            android:layout_marginBottom="8dp" />

        <RadioButton
            android:id="@+id/rbHighest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Highest Amount"
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="@color/colorPrimary"
            android:layout_marginBottom="8dp" />

        <RadioButton
            android:id="@+id/rbLowest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lowest Amount"
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="@color/colorPrimary"
            android:layout_marginBottom="8dp" />

    </RadioGroup>

    <!-- Apply Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplySort"
        style="@style/ClayButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Apply Sorting" />

</LinearLayout>
