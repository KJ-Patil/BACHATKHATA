<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top App Bar Toolbar -->
    <RelativeLayout
        android:id="@+id/layoutAppBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/transaction_details"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnEditToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_more"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/btnDelete"
        app:layout_constraintTop_toBottomOf="@+id/layoutAppBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Hero Category Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/ClayCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <FrameLayout
                        android:id="@+id/layoutHeroIconFrame"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_clay_button"
                        android:backgroundTint="@color/colorPrimary"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/txtHeroEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🍔"
                            android:textSize="30sp" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/txtHeroAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹500.00"
                        android:textColor="@color/colorDanger"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtHeroCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Food"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- READ ONLY DETAIL LAYOUT -->
            <LinearLayout
                android:id="@+id/layoutReadMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Type -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Type"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Expense"
                                android:textColor="@color/colorDanger"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Date -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="12 Jun 2026"
                                android:textColor="@color/colorTextPrimary"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Account -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Account"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailAccount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Cash"
                                android:textColor="@color/colorTextPrimary"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Currency -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Currency"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/txtDetailCurrency"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="INR (₹)"
                                android:textColor="@color/colorTextPrimary"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Discount breakdown: only present when one was applied,
                             so the row set is unchanged for ordinary transactions. -->
                        <LinearLayout
                            android:id="@+id/layoutDiscountDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/discount_detail_original"
                                    android:textColor="@color/colorTextSecondary" />
                                <TextView
                                    android:id="@+id/txtDetailOriginalAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textStyle="bold" />
                            </RelativeLayout>

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/discount_detail_saved"
                                    android:textColor="@color/colorTextSecondary" />
                                <TextView
                                    android:id="@+id/txtDetailDiscountAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:textColor="@color/colorSuccess"
                                    android:textStyle="bold" />
                            </RelativeLayout>
                        </LinearLayout>

                        <!-- Note -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Note"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/txtDetailNote"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="No note"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="15sp"
                                android:lineSpacingExtra="2dp" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- EDITABLE FORM LAYOUT ( inicialmente invisible ) -->
            <LinearLayout
                android:id="@+id/layoutEditMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Editable Amount Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEditAmount"
                    style="@style/ClayInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Amount">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/colorTextPrimary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Category grid RecyclerView -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Change Category"
                    android:textColor="@color/colorTextPrimary"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEditCategoryGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="4" />

                <!-- Note Input Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEditNote"
                    style="@style/ClayInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/add_note">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textShortMessage|textCapSentences"
                        android:textColor="@color/colorTextPrimary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Date Picker trigger -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEditDatePicker"
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <ImageView
                            android:id="@+id/imgEditCalendarIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_calendar"
                            android:layout_centerVertical="true" />
                        <TextView
                            android:id="@+id/txtEditDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Date"
                            android:textColor="@color/colorTextPrimary"
                            android:textStyle="bold"
                            android:layout_toEndOf="@+id/imgEditCalendarIcon"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Account Selector trigger -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEditAccountSelector"
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <ImageView
                            android:id="@+id/imgEditWalletIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_wallet"
                            android:layout_centerVertical="true" />
                        <TextView
                            android:id="@+id/txtEditAccount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cash"
                            android:textColor="@color/colorTextPrimary"
                            android:textStyle="bold"
                            android:layout_toEndOf="@+id/imgEditWalletIcon"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Delete / Save Changes Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDelete"
        style="@style/ClayButtonSecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:text="Delete Transaction"
        android:textColor="@color/colorDanger"
        app:strokeColor="@color/colorDanger"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Overlay Loader -->
    <FrameLayout
        android:id="@+id/loaderOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorScrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/colorPrimary" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
