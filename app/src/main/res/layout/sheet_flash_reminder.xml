<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_clay_card"
    android:backgroundTint="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_bell"
                android:contentDescription="@string/reminder_title"
                app:tint="@color/colorPrimary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/reminder_title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtReminderSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

        <!-- Tone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/reminder_tone"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupTone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipToneFriendly"
                style="@style/ClayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/reminder_tone_friendly" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipToneFormal"
                style="@style/ClayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reminder_tone_formal" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipToneUrgent"
                style="@style/ClayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reminder_tone_urgent" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/reminder_language"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupLang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLangEn"
                style="@style/ClayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/reminder_lang_en" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLangHi"
                style="@style/ClayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reminder_lang_hi" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLangMr"
                style="@style/ClayChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reminder_lang_mr" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Editable draft -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/reminder_message"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etReminderMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="4"
                android:maxLines="8"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dispatch: two real channels, nothing simulated -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendWhatsApp"
            style="@style/ClayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/reminder_send_whatsapp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendSms"
            style="@style/ClayButtonSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reminder_send_sms" />

    </LinearLayout>
</ScrollView>
