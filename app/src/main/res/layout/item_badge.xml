<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/ClayCard"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:strokeWidth="0dp"
    app:cardCornerRadius="0dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_card_3d"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/layoutBadgeIconContainer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/dot_pin_filled"
            android:backgroundTint="@color/colorPrimaryTint">

            <ImageView
                android:id="@+id/imgBadgeIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="@color/colorPrimary" />

            <ImageView
                android:id="@+id/imgLockOverlay"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_lock"
                app:tint="@color/colorTextSecondary"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtBadgeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Badge Name"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txtBadgeDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Badge description goes here."
            android:textColor="@color/colorTextSecondary"
            android:textSize="10sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
