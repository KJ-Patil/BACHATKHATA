<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Handle indicator -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Liability"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Liability Type Dropdown/Spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Liability Type"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/ClayCard"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#F8F7FF">

            <Spinner
                android:id="@+id/spinnerLiabilityType"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="12dp"
                android:entries="@array/liability_types"
                android:background="@null" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Liability Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLiabilityName"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Liability Name (e.g. HDFC Credit Card)"
            android:layout_marginBottom="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLiabilityName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Liability Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLiabilityAmount"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Outstanding Amount (₹)"
            android:layout_marginBottom="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLiabilityAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Notes -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLiabilityNotes"
            style="@style/ClayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notes (Optional)"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLiabilityNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textShortMessage"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveLiability"
            style="@style/ClayButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Liability"
            app:backgroundTint="#E24B4A"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
