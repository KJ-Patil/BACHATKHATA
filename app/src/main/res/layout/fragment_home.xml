<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/home_content_padding">

                <!-- A. Header Section -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good morning, User"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="@dimen/text_size_greeting"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtDateSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="June 2026"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Notification Bell Container -->
                    <FrameLayout
                        android:id="@+id/btnNotificationBell"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_email"
                            app:tint="@color/colorTextPrimary" />

                        <TextView
                            android:id="@+id/txtNotificationBadge"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="4dp"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_clay_button"
                            android:backgroundTint="@color/colorDanger"
                            android:gravity="center"
                            android:textColor="@android:color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:text="3"
                            android:visibility="gone" />
                    </FrameLayout>
                </RelativeLayout>

                <!-- Search Box -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSearchHome"
                    style="@style/ClayInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:hint="Search transactions..."
                    app:startIconDrawable="@drawable/ic_search"
                    app:startIconTint="@color/colorTextSecondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearchHome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/colorTextPrimary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Quick Actions Row + Today's Summary pill -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btnDataTools"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_today_pill"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="46dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="14dp">

                    <com.google.android.material.card.MaterialCardView
                        style="@style/ClayCard"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:clickable="false"
                        android:focusable="false"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@color/colorCardBorder"
                        app:strokeWidth="1dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/colorSurface"
                            android:gravity="center"
                            android:text="🧰"
                            android:textSize="13sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Data &amp; Tools"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ledger, EMI, Export &amp; more"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/colorTextSecondary" />
                </LinearLayout>

                    <!-- Spacer pushes the pill to the end of the row -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Today's summary pill (next to Data & Tools) -->
                    <LinearLayout
                        android:id="@+id/cardTodaySummaryPill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_today_pill"
                        android:paddingHorizontal="14dp"
                        android:minHeight="46dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_wallet"
                            app:tint="@color/colorTextPrimary" />

                        <TextView
                            android:id="@+id/txtTodaySummaryText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Spent ₹0.00 today"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Container for dashboard widgets to hide during search -->
                <LinearLayout
                    android:id="@+id/layoutDashboardWidgets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <!-- B. Balance Hero Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBalanceHero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:outlineSpotShadowColor="#80000000"
                    android:outlineAmbientShadowColor="#66000000"
                    app:cardBackgroundColor="@color/colorPrimary"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Available Balance"
                            android:textColor="#B3FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtBalanceAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="₹0.00"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/text_size_balance_hero"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="#33FFFFFF" />

                        <!-- Income and spent summary -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Income -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Income"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/txtHeroIncome"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="₹0.00"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                        android:background="#33FFFFFF" />

                            <!-- Spent -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Spent"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/txtHeroSpent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="₹0.00"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- B2. Safe-to-Spend Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSafeToSpend"
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_3d_accent"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Safe to spend today"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtSafeToSpendAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₹0.00"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtSafeToSpendSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="₹0.00 left · 0 days"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛟"
                            android:textSize="32sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- C. KPI Grid (2x2) -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginBottom="20dp"
                    android:alignmentMode="alignBounds">

                    <!-- Card 1: Total Income -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardKpiIncome"
                        style="@style/ClayCard"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:strokeWidth="0dp"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_card_3d"
                            android:padding="16dp">
                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_kpi_dot"
                                android:backgroundTint="@color/colorSecondary"/>
                            <TextView
                                android:id="@+id/txtKpiIncome"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="₹0.0"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:letterSpacing="0.02"
                                android:text="Total Income"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 2: Total Spent -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardKpiSpent"
                        style="@style/ClayCard"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:strokeWidth="0dp"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_card_3d"
                            android:padding="16dp">
                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_kpi_dot"
                                android:backgroundTint="@color/colorDanger"/>
                            <TextView
                                android:id="@+id/txtKpiSpent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="₹0.0"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:letterSpacing="0.02"
                                android:text="Total Spent"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 3: Total Saved -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardKpiSaved"
                        style="@style/ClayCard"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:strokeWidth="0dp"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_card_3d"
                            android:padding="16dp">
                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_kpi_dot"
                                android:backgroundTint="@color/colorPrimary"/>
                            <TextView
                                android:id="@+id/txtKpiSaved"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="₹0.0"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:letterSpacing="0.02"
                                android:text="Total Saved"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 4: Total Txns -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardKpiTxnCount"
                        style="@style/ClayCard"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_rowWeight="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:strokeWidth="0dp"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_card_3d"
                            android:padding="16dp">
                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_kpi_dot"
                                android:backgroundTint="@color/colorAccent"/>
                            <TextView
                                android:id="@+id/txtKpiTxnCount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="0"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:letterSpacing="0.02"
                                android:text="Transactions"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>

                <!-- D. Period Filter Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp">
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPeriod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipDaily"
                            style="@style/ClayChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMonthly"
                            style="@style/ClayChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipQuarterly"
                            style="@style/ClayChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quarterly" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipYearly"
                            style="@style/ClayChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Yearly" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <!-- D2. Chart Filter Toggle (Income / Spent / Both) -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupChartMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipChartBoth"
                        style="@style/ClayChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Both"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipChartIncome"
                        style="@style/ClayChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Income" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipChartSpent"
                        style="@style/ClayChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spent" />
                </com.google.android.material.chip.ChipGroup>

                <!-- E. Spending Trend Line Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spending Trend"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>
                    <com.google.android.material.card.MaterialCardView
                        style="@style/ClayCard"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/chart_card_height"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_card_3d">
                            <com.github.mikephil.charting.charts.LineChart
                                android:id="@+id/lineChart"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/chart_inner_height"
                                android:layout_gravity="center"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- F. Category Breakdown Bar Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="By Category"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <com.google.android.material.card.MaterialCardView
                        style="@style/ClayCard"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/chart_card_height"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_card_3d">
                            <com.github.mikephil.charting.charts.BarChart
                                android:id="@+id/barChart"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/chart_inner_height"
                                android:layout_gravity="center"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Weekly Insights Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWeeklyInsight"
                    style="@style/ClayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_3d_amber"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Weekly Insight"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/btnDismissInsight"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_trash"
                                app:tint="@color/colorTextSecondary"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/txtWeeklyInsightContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="You spent a total of ₹0.00 this past week. Review your transaction log in the app."
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- G. Recent Transactions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="32dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/txtRecentTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Recent"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSeeAll"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="See all"
                            android:textColor="@color/colorPrimary"/>
                    </RelativeLayout>

                    <!-- Transactions RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_transaction"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
